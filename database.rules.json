{
  "rules": {
    /*
      TOBALDINE SIGNATURE · FIREBASE SECURITY RULES
      ================================================
      COMO APLICAR:
      1. Acesse console.firebase.google.com → seu projeto
      2. Realtime Database → Rules
      3. Substitua o conteúdo pelas regras abaixo e clique em Publish

      LÓGICA:
      - produtos / kits / depoimentos / config: leitura pública (catálogo precisa)
      - cupons: leitura pública (validação de desconto no catálogo)
      - pedidos / caixa: somente admin autenticado (dados sensíveis de negócio)
      - Escrita em TUDO: somente admin autenticado (auth != null)
    */

    "produtos": {
      ".read": true,
      ".write": "auth != null"
    },
    "kits": {
      ".read": true,
      ".write": "auth != null"
    },
    "depoimentos": {
      ".read": true,
      ".write": "auth != null"
    },
    "config": {
      /*
        Sub-nós públicos (catálogo precisa ler sem autenticação):
        textos, secoes, mostrarEstoque, tel
        Sub-nós privados (chaves de API — nunca públicas):
        geminiKey, removebgKey
      */
      "textos":         { ".read": true,            ".write": "auth != null" },
      "secoes":         { ".read": true,            ".write": "auth != null" },
      "mostrarEstoque": { ".read": true,            ".write": "auth != null" },
      "tel":            { ".read": true,            ".write": "auth != null" },
      "geminiKey":      { ".read": "auth != null",  ".write": "auth != null" },
      "removebgKey":    { ".read": "auth != null",  ".write": "auth != null" },
      "$configOther":   { ".read": false,           ".write": false }
    },
    "cupons": {
      ".read": true,
      ".write": "auth != null"
    },
    "pedidos": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "historico": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "caixa": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
